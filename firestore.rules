rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: workOrders
    // Document ID: Auto-generated or custom Work Order ID
    // Fields:
    //   - id: string
    //   - material: string
    //   - qty: number
    //   - weight: number
    //   - authorId: string (immutable)
    //   - ... other optional fields
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() == 'admin')) ||
          (request.auth.token.email == "a.shahin.mamdouh@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isManager() {
      return isAuthenticated() &&
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role.lower() == 'manager')));
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }
    
    function uidUnchanged() {
      return !('authorId' in request.resource.data) ||
        request.resource.data.authorId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('authorId' in request.resource.data) ||
        request.resource.data.authorId == resource.data.authorId;
    }

    function isValidWorkOrder(data) {
      return data.id is string && data.id.size() > 0 &&
             data.material is string && data.material.size() > 0 &&
             data.qty is number && data.qty > 0 &&
             data.weight is number && data.weight >= 0 &&
             data.authorId is string && data.authorId.size() > 0 &&
             (!('status' in data) || (data.status is string && data.status.size() > 0));
    }

    function isValidOvertimeRequest(data) {
      return data.operator is string && data.operator.size() > 0 &&
             data.operatorId is string && data.operatorId.size() > 0 &&
             data.workshop is string && data.workshop.size() > 0 &&
             data.date is string &&
             data.timeFrom is string &&
             data.timeTo is string &&
             data.hours is number &&
             data.status in ['Pending', 'Approved', 'Rejected'] &&
             data.authorId is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /test/connection {
      allow read: if true;
      allow write: if false;
    }

    match /users/{docId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.email == request.auth.token.email);
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.email == request.auth.token.email && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName']));
      allow delete: if isAdmin();
    }

    match /workOrders/{docId} {
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && (isAdmin() || (isValidWorkOrder(request.resource.data) && uidNotModified()));
      allow create: if isAuthenticated() && (isAdmin() || (isValidWorkOrder(request.resource.data) && uidUnchanged()));
      allow delete: if isAdmin() || isDocOwner();
    }

    match /workshop_records/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || uidUnchanged());
      allow update: if isAuthenticated() && (isAdmin() || uidNotModified());
      allow delete: if isAdmin() || isDocOwner();
    }

    match /overtime_requests/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (isAdmin() || (uidUnchanged() && isValidOvertimeRequest(request.resource.data)));
      allow update: if isAdmin() || isManager() || (isDocOwner() && resource.data.status == 'Pending' && uidNotModified() && isValidOvertimeRequest(request.resource.data));
      allow delete: if isAdmin() || (isDocOwner() && resource.data.status == 'Pending');
    }

    match /master_materials/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /master_products/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /master_processes/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /master_status/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /master_workshops/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /master_operators/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /master_machines/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /master_molds/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /master_routing/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /master_rejections/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /quality_inspections/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /inventory_records/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /inventory_raw/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /inventory_fg/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /inventory_wip_product/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /inventory_wip_raw/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /inventory_issue/{docId} { allow read: if isAuthenticated(); allow write: if isAdmin() || isManager(); }
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
  }
}
