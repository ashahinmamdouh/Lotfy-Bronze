rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: workOrders
    // Document ID: Auto-generated or custom Work Order ID
    // Fields:
    //   - id: string
    //   - material: string
    //   - qty: number
    //   - weight: number
    //   - authorId: string (immutable)
    //   - ... other optional fields
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorId;
    }
    
    function uidUnchanged() {
      return !('authorId' in request.resource.data) ||
        request.resource.data.authorId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('authorId' in request.resource.data) ||
        request.resource.data.authorId == resource.data.authorId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidWorkOrder(data) {
      return data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.material is string && data.material.size() > 0 && data.material.size() < 100 &&
             data.qty is number && data.qty > 0 &&
             data.weight is number && data.weight >= 0 &&
             data.authorId is string && data.authorId.size() > 0 &&
             (!('fullName' in data) || (data.fullName is string && data.fullName.size() < 500)) &&
             (!('moldNo' in data) || (data.moldNo is string && data.moldNo.size() < 100));
    }

    match /test/connection {
      allow read: if true;
      allow write: if false;
    }

    match /master_materials/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /master_products/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /master_processes/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /master_status/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /master_workshops/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /master_operators/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /master_machines/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /master_molds/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /master_routing/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /master_rejections/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /workshop_records/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /quality_inspections/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /inventory_records/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /inventory_raw/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /inventory_fg/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /inventory_wip_product/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /inventory_wip_raw/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    match /inventory_issue/{docId} { allow read: if isAuthenticated(); allow create: if isAuthenticated() && uidUnchanged(); allow update: if isAuthenticated() && uidNotModified(); allow delete: if isDocOwner(); }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin' ||
          (request.auth.token.email == "a.shahin.mamdouh@gmail.com" && request.auth.token.email_verified == true));
    }

    function isManager() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Manager' ||
         isAdmin());
    }

    function isValidOvertimeRequest(data) {
      return data.operator is string && data.operator.size() > 0 &&
             data.operatorId is string && data.operatorId.size() > 0 &&
             data.workshop is string && data.workshop.size() > 0 &&
             data.date is string &&
             data.timeFrom is string &&
             data.timeTo is string &&
             data.hours is number &&
             data.status in ['Pending', 'Approved', 'Rejected'] &&
             data.authorId is string;
    }

    match /overtime_requests/{docId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && uidUnchanged() && isValidOvertimeRequest(request.resource.data);
      allow update: if isAuthenticated() && uidNotModified() && (
        // Owner can update if still Pending
        (isDocOwner() && resource.data.status == 'Pending' && isValidOvertimeRequest(request.resource.data)) ||
        // Admin/Manager can update status
        (isManager() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'processedBy', 'processedAt']))
      );
      allow delete: if isDocOwner() && resource.data.status == 'Pending';
    }

    match /settings/{docId} { allow read: if true; allow write: if isAuthenticated(); }

    match /users/{docId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.email == request.auth.token.email);
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAuthenticated() && resource.data.email == request.auth.token.email && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName']));
      allow delete: if isAdmin();
    }

    match /workOrders/{orderId} {
      allow read: if isAuthenticated();
      
      allow create: if isAuthenticated() && 
                    hasRequiredFields(['id', 'material', 'qty', 'weight', 'authorId']) &&
                    isValidWorkOrder(request.resource.data) &&
                    uidUnchanged();
                    
      allow update: if isAuthenticated() && 
                    isValidWorkOrder(request.resource.data) &&
                    uidNotModified();
                    
      allow delete: if isDocOwner();
    }
  }
}
